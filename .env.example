# Supabase（必填 — 云端数据同步）
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# 千问 API（国内大模型，推荐）
REACT_APP_QWEN_API_KEY=sk-ws-...
REACT_APP_QWEN_BASE_URL=https://ws-xxx.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
REACT_APP_QWEN_MODEL=qwen-plus
REACT_APP_DEFAULT_AI_MODEL=qwen

# Gemini（可选备用）
REACT_APP_GEMINI_API_KEY=

# 其他可选 API
REACT_APP_HUNTER_API_KEY=
